# ==============================================================
# InDiiServe Nova Sonic Voice Agent — Example Environment File
# Copy this file to .env and replace ALL dummy values with real ones.
# NEVER put real credentials in this file — it is safe to commit.
# ==============================================================

# --- Mode & Tenant ---
DEMO_MODE=false
HOSPITAL_ID=your_hospital_id

# ==============================================================
# AWS Credentials (MANDATORY — required for Bedrock Nova Sonic)
# ==============================================================
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
AWS_REGION=ap-south-1
BEDROCK_REGION=us-east-1

# ==============================================================
# Exotel Telephony (Required for real voice calls)
# ==============================================================
EXOTEL_API_KEY=your_exotel_api_key
EXOTEL_API_TOKEN=your_exotel_api_token
EXOTEL_SID=your_exotel_account_sid
EXOTEL_SUBDOMAIN=api.exotel.com
EXOTEL_FROM_NUMBER=+910000000000
EXOTEL_APP_ID=your_exotel_app_id
SIP_ENDPOINT=sip:your_sip_endpoint@sip.example.com

# [CRIT-02] Shared WebSocket secret — add as query param in Exotel App Bazar WebSocket URL
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
EXOTEL_WS_SECRET=your_generated_ws_secret_here

# ==============================================================
# Server Config
# ==============================================================
PORT=8000

# [CRITICAL] Must be your public EC2/domain URL — Exotel is a cloud service, localhost won't work
# Set this AFTER you get your EC2 public IP or domain
# Format: wss://YOUR_IP_OR_DOMAIN/exotel-stream
WS_PUBLIC_URL=wss://your-ec2-ip-or-domain.com/exotel-stream

# ==============================================================
# Security
# ==============================================================

# [CRIT-01] Fernet PII encryption key — KEEP THIS SECRET
# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your_fernet_key_here_replace_with_generated_value

# [MED-07] Bearer token for /health endpoint metrics (optional but recommended)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
HEALTH_CHECK_TOKEN=your_health_check_token_here

# [MED-01] Allowed CORS origins — comma-separated. Use * for dev only
CORS_ORIGINS=*

# ==============================================================
# AWS DynamoDB (Call Transcript Storage)
# ==============================================================
DYNAMODB_TABLE_NAME=InDiiServe_Call_Transcript_1

# ==============================================================
# AWS RDS Postgres (Analytics Pipeline)
# Leave RDS_HOSTNAME empty to use local SQLite (demo/dev mode)
# ==============================================================
RDS_HOSTNAME=your-rds-instance.abc123.ap-south-1.rds.amazonaws.com
RDS_PORT=5432
RDS_USERNAME=indiiserve_user
RDS_DB_NAME=indiiserve_analytics

# ==============================================================
# Bedrock: Knowledge Base (RAG — hospitalInfoTool)
# ==============================================================
KB_ID=your_bedrock_kb_id
KB_REGION=ap-south-1

# ==============================================================
# Bedrock: AgentCore Memory (Patient Recognition across calls)
# ==============================================================
MEMORY_ID=your_agentcore_memory_id
MEMORY_REGION=ap-south-1

# ==============================================================
# Bedrock: Analytics Model (Post-call AI analysis)
# ==============================================================
ANALYTICS_MODEL_ID=amazon.nova-lite-v1:0

# ==============================================================
# Google Sheets Integration (Appointment Booking Sink)
# ==============================================================
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# ==============================================================
# FAISS Semantic Cache Limits (MED-03)
# ==============================================================
FAISS_MAX_ENTRIES=10000
FAISS_KEEP_ENTRIES=8000
