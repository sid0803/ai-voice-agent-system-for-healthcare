# ----------------------------------------------------------
# InDiiServe Asha Healthcare AI — Environment Variables
# Copy this file to .env and fill in your values.
# ----------------------------------------------------------

# --- Exotel Telephony Credentials ---
EXOTEL_API_KEY=
EXOTEL_API_TOKEN=
EXOTEL_SID=
EXOTEL_SUBDOMAIN=
EXOTEL_FROM_NUMBER=
EXOTEL_APP_ID=
SIP_ENDPOINT=

# --- AWS Credentials & Region ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1

# --- Bedrock: Nova Sonic (Voice AI) ---
BEDROCK_REGION=us-east-1

# --- Bedrock: Knowledge Base (RAG for hospitalInfoTool) ---
KB_ID=
KB_REGION=ap-south-1

# --- Bedrock: AgentCore Memory (Patient Recognition) ---
MEMORY_ID=
MEMORY_REGION=ap-south-1

# --- Bedrock: Analytics Model (Post-Call AI Analysis) ---
# Default: amazon.nova-lite-v1:0 (cost-effective, keep this unless changing)
ANALYTICS_MODEL_ID=amazon.nova-lite-v1:0

# --- DynamoDB: Call Transcript Audit Vault ---
DYNAMODB_TABLE_NAME=InDiiServe_Call_Transcript_1

# --- RDS Postgres: Analytics Pipeline ---
RDS_HOSTNAME=
RDS_PORT=5432
RDS_USERNAME=indiiserve_user
RDS_DB_NAME=indiiserve_analytics

# --- Google Sheets Integration (Booking Notedown) ---
GOOGLE_SHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# --- Multi-Tenancy & Server ---
HOSPITAL_ID=default_tier2
WS_PUBLIC_URL=
PORT=3000
# Symmetric encryption key for PII (Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=
